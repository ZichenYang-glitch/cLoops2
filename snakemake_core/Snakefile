rule annotate_loops:
    input:
        analysis_meta_file(PRIMARY_GROUP),
        f"{report_prefix(PRIMARY_GROUP)}_loops.txt"
    output:
        touch(annotation_done()),
        f"{annotation_prefix()}_LoopsGtfAno.txt"
    params:
        loops=f"{report_prefix(PRIMARY_GROUP)}_loops.txt",
        prefix=annotation_prefix(),
        gtf=REFERENCES.get("gtf", ""),
        args=PARAMS.get("annotation", "-net"),
        cmd=CLOOPS2_CMD
    log:
        os.path.join(LOG_DIR, "annotation", f"{PRIMARY_GROUP}.anaLoops.log")
    shell:
        r"""
        mkdir -p "$(dirname "{output[0]}")" "$(dirname "{log}")"
        {params.cmd} anaLoops -loops "{params.loops}" -o "{params.prefix}" -gtf "{params.gtf}" {params.args} > "{log}" 2>&1
        touch "{output[0]}"
        """
