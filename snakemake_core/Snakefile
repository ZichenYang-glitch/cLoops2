import os
import json
from pathlib import Path

configfile: "config.yaml"

PROJECT = config["project_name"]
OUTPUT_ROOT = config["output_root"]
SAMPLES = config["samples"]
GROUPS = config["groups"]
PRIMARY_GROUP = config["primary_group"]
SECONDARY_GROUP = config.get("secondary_group", PRIMARY_GROUP)
CALLING_GROUPS = config.get("calling_groups", [PRIMARY_GROUP])
PARAMS = config.get("params", {})
NORMALIZATION = config.get("normalization", {})
CLOOPS2_CMD = config.get("cloops2_cmd", "cLoops2")
SPECIES = config.get("species", "human")
CHROM_WHITELIST = config.get("chrom_whitelist", {})
COMPARE = config.get("compare", {})
VIS = config.get("vis", {})
REFERENCES = config.get("references", {})
PLOT_REGIONS = config.get("plot_regions", {})
ANNOTATION = config.get("annotation", {})

DATA_DIR = os.path.join(OUTPUT_ROOT, "datasets")
REPORT_DIR = os.path.join(OUTPUT_ROOT, "reports")
STATE_DIR = os.path.join(OUTPUT_ROOT, ".snakemake_state")
LOG_DIR = os.path.join(OUTPUT_ROOT, "logs")

ALL_SAMPLES = sorted(SAMPLES.keys())
ALL_GROUPS = sorted(GROUPS.keys())
NORMALIZE_ENABLED = NORMALIZATION.get("enabled", False)
NORMALIZE_GROUPS = NORMALIZATION.get("groups", [])
NORMALIZE_SUFFIX = NORMALIZATION.get("output_suffix", "_norm")
NORMALIZE_MODE = NORMALIZATION.get("mode", "min_unique_pets")
COMPARE_ENABLED = COMPARE.get("enabled", False)
COMPARE_MONTAGE_ENABLED = COMPARE.get("montage_enabled", False)
COMPARE_GROUPS = COMPARE.get("groups", [PRIMARY_GROUP, SECONDARY_GROUP])
COMPARE_SUFFIX = COMPARE.get("output_suffix", "_cmp")
COMPARE_MODE = COMPARE.get("mode", "min_unique_pets")
VIS_ENABLED = VIS.get("enabled", False)
VIS_PLOT_ENABLED = VIS.get("plot_enabled", False)
ANNOTATION_ENABLED = ANNOTATION.get("enabled", False)
SAMPLE_PATTERN = "|".join(ALL_SAMPLES)
GROUP_PATTERN = "|".join(ALL_GROUPS)
CALLING_GROUP_PATTERN = "|".join(CALLING_GROUPS)
NORMALIZE_GROUP_PATTERN = "|".join(NORMALIZE_GROUPS) if NORMALIZE_GROUPS else "$^"
COMPARE_GROUP_PATTERN = "|".join(COMPARE_GROUPS) if COMPARE_GROUPS else "$^"
PRE_ARGS = f"-c {CHROM_WHITELIST[SPECIES]} {PARAMS.get('pre_extra', '')}".strip()
CHROM_PAIR = f"{config.get('view_chrom', config.get('target_chroms', 'chr21'))}-{config.get('view_chrom', config.get('target_chroms', 'chr21'))}"


def ensure_parent(path):
    Path(path).parent.mkdir(parents=True, exist_ok=True)


def dataset_dir(name):
    return os.path.join(DATA_DIR, name)


def report_prefix(name):
    return os.path.join(REPORT_DIR, name)


def state_file(*parts):
    return os.path.join(STATE_DIR, *parts)


def sample_done(sample):
    return state_file("pre", f"{sample}.done")


def group_done(group):
    return state_file("groups", f"{group}.done")


def meta_file(name):
    return os.path.join(dataset_dir(name), "petMeta.json")


def est_res_done(group):
    return state_file("estimate", f"{group}.estRes.done")


def est_dis_done(group):
    return state_file("estimate", f"{group}.estDis.done")


def est_sim_done():
    return state_file("estimate", "all.estSim.done")


def group_replicates(group):
    return GROUPS[group]["replicates"]


def group_build_mode(group):
    return GROUPS[group].get("build_mode", "pre")


def normalized_group_name(group):
    return f"{group}{NORMALIZE_SUFFIX}"


def should_normalize(group):
    return NORMALIZE_ENABLED and group in NORMALIZE_GROUPS


def analysis_group_name(group):
    return normalized_group_name(group) if should_normalize(group) else group


def analysis_dataset_dir(group):
    return dataset_dir(analysis_group_name(group))


def analysis_meta_file(group):
    return meta_file(analysis_group_name(group))


def normalize_done(group):
    return state_file("normalize", f"{group}.done")


def normalized_meta_file(group):
    return meta_file(normalized_group_name(group))


def compare_group_name(group):
    return f"{group}{COMPARE_SUFFIX}"


def compare_loop_prefix(group):
    return report_prefix(compare_group_name(group))


def compare_loop_file(group):
    return f"{compare_loop_prefix(group)}_loops.txt"


def compare_diff_done():
    return state_file("compare", f"{PRIMARY_GROUP}_vs_{SECONDARY_GROUP}.done")


def vis_done(name):
    return state_file("vis", f"{name}.done")


def annotation_done():
    return state_file("annotation", f"{PRIMARY_GROUP}.done")


def annotation_prefix():
    return report_prefix(f"{PRIMARY_GROUP}_loops")


def plot_region(name):
    if name not in PLOT_REGIONS:
        raise ValueError(f"plot_regions.{name} is required when plot is enabled")
    return PLOT_REGIONS[name]


def plot_fixy(base_dir, region_name):
    chrom = plot_region(region_name)["chrom"]
    return os.path.join(base_dir, f"{chrom}-{chrom}.ixy")


def region_core_args(region_name, include_bs=True):
    region = plot_region(region_name)
    parts = []
    if include_bs and "bs" in region:
        parts.extend(["-bs", str(region["bs"])])
    parts.extend(["-start", str(region["start"]), "-end", str(region["end"])])
    return " ".join(parts)


def sample_files_csv(sample_names):
    return ",".join(SAMPLES[sample] for sample in sample_names)


def sample_dirs_csv(sample_names):
    return ",".join(dataset_dir(sample) for sample in sample_names)


def million_floor_target(counts):
    min_count = min(counts)
    target = (min_count // 1000000) * 1000000
    if target <= 0:
        raise ValueError(
            f"minimum Unique PETs is {min_count}, rounded-to-million target becomes 0 and cannot be used for samplePETs"
        )
    return target


SAMPLE_PRE_MARKERS = [sample_done(sample) for sample in ALL_SAMPLES]
GROUP_MARKERS = [group_done(group) for group in ALL_GROUPS]
EST_RES_MARKERS = [est_res_done(group) for group in ALL_GROUPS]
CALL_PEAK_OUTPUTS = [f"{report_prefix(group)}_peaks.bed" for group in CALLING_GROUPS]
CALL_LOOP_OUTPUTS = [f"{report_prefix(group)}_loops.txt" for group in CALLING_GROUPS]
CALL_DOMAIN_OUTPUTS = [f"{report_prefix(group)}_domains.bed" for group in CALLING_GROUPS]
NORMALIZE_TARGET_FILE = state_file("normalize", "target_unique_pets.txt")
NORMALIZE_MARKERS = [normalize_done(group) for group in NORMALIZE_GROUPS] if NORMALIZE_ENABLED else []
COMPARE_LOOP_OUTPUTS = [compare_loop_file(group) for group in COMPARE_GROUPS] if COMPARE_ENABLED else []
COMPARE_FINAL_OUTPUTS = (
    [compare_diff_done()] +
    ([vis_done("montage_all"), vis_done("montage_viewpoint")] if COMPARE_MONTAGE_ENABLED else []) +
    COMPARE_LOOP_OUTPUTS
) if COMPARE_ENABLED else []
VIS_OUTPUTS = [
    vis_done("agg_peaks"),
    vis_done("agg_viewpoints"),
    vis_done("agg_loops"),
    vis_done("agg_domains"),
    vis_done("filtered_data"),
] if VIS_ENABLED else []
PLOT_OUTPUTS = [
    vis_done("plot_domain"),
    vis_done("plot_loop"),
    vis_done("filtered_plot"),
    vis_done("plot_arch"),
] if VIS_ENABLED and VIS_PLOT_ENABLED else []
PLOT_MANUAL_OUTPUTS = [
    vis_done("plot_domain"),
    vis_done("plot_loop"),
    vis_done("filtered_plot"),
    vis_done("plot_arch"),
]
ANNOTATION_OUTPUTS = [
    annotation_done(),
    f"{annotation_prefix()}_LoopsGtfAno.txt",
] if ANNOTATION_ENABLED else []


rule all:
    input:
        f"{report_prefix('qc')}_bedpeQc.txt",
        SAMPLE_PRE_MARKERS,
        GROUP_MARKERS,
        NORMALIZE_MARKERS,
        EST_RES_MARKERS,
        est_dis_done(PRIMARY_GROUP),
        est_sim_done(),
        CALL_PEAK_OUTPUTS,
        CALL_LOOP_OUTPUTS,
        CALL_DOMAIN_OUTPUTS,
        COMPARE_FINAL_OUTPUTS,
        VIS_OUTPUTS,
        PLOT_OUTPUTS,
        ANNOTATION_OUTPUTS,


rule plot_all:
    input:
        PLOT_MANUAL_OUTPUTS


rule annotation:
    input:
        ANNOTATION_OUTPUTS


rule pre_sample:
    wildcard_constraints:
        sample=SAMPLE_PATTERN
    input:
        lambda wc: SAMPLES[wc.sample]
    output:
        touch(sample_done("{sample}")),
        meta_file("{sample}")
    params:
        outdir=lambda wc: dataset_dir(wc.sample),
        args=PRE_ARGS,
        cmd=CLOOPS2_CMD
    log:
        os.path.join(LOG_DIR, "pre", "{sample}.log")
    shell:
        r"""
        mkdir -p "{params.outdir}" "$(dirname "{log}")" "$(dirname "{output[0]}")"
        {params.cmd} pre -f "{input}" -o "{params.outdir}" {params.args} > "{log}" 2>&1
        touch "{output[0]}"
        """


rule build_group:
    wildcard_constraints:
        group=GROUP_PATTERN
    input:
        lambda wc: [sample_done(sample) for sample in group_replicates(wc.group)]
    output:
        touch(group_done("{group}")),
        meta_file("{group}")
    params:
        outdir=lambda wc: dataset_dir(wc.group),
        files=lambda wc: sample_files_csv(group_replicates(wc.group)),
        dirs=lambda wc: sample_dirs_csv(group_replicates(wc.group)),
        args=PRE_ARGS,
        combine_args=lambda wc: PARAMS.get("combine", ""),
        cmd=CLOOPS2_CMD
    log:
        os.path.join(LOG_DIR, "groups", "{group}.log")
    run:
        ensure_parent(output[0])
        ensure_parent(output[1])
        ensure_parent(log[0])
        mode = group_build_mode(wildcards.group)
        if mode == "pre":
            shell(
                r'''
                mkdir -p "{params.outdir}"
                {params.cmd} pre -f "{params.files}" -o "{params.outdir}" {params.args} > "{log}" 2>&1
                touch "{output[0]}"
                '''
            )
        elif mode == "combine":
            shell(
                r'''
                if [ -d "{params.outdir}" ] && [ -z "$(ls -A "{params.outdir}")" ]; then rmdir "{params.outdir}"; fi
                {params.cmd} combine -ds "{params.dirs}" -o "{params.outdir}" {params.combine_args} > "{log}" 2>&1
                touch "{output[0]}"
                '''
            )
        else:
            raise ValueError(f"unsupported build_mode for {wildcards.group}: {mode}")


rule normalize_target_depth:
    input:
        lambda wc: [meta_file(group) for group in NORMALIZE_GROUPS]
    output:
        NORMALIZE_TARGET_FILE
    run:
        ensure_parent(output[0])
        if not NORMALIZE_ENABLED:
            Path(output[0]).write_text("")
            return
        if NORMALIZE_MODE != "min_unique_pets":
            raise ValueError(f"unsupported normalization mode: {NORMALIZE_MODE}")
        counts = []
        for path in input:
            with open(path) as fh:
                meta = json.load(fh)
            counts.append(int(meta["Unique PETs"]))
        Path(output[0]).write_text(str(million_floor_target(counts)))


rule normalize_group:
    wildcard_constraints:
        group=NORMALIZE_GROUP_PATTERN
    input:
        group_meta=meta_file("{group}"),
        group_done=group_done("{group}"),
        target=NORMALIZE_TARGET_FILE
    output:
        touch(normalize_done("{group}")),
        normalized_meta_file("{group}")
    params:
        indir=lambda wc: dataset_dir(wc.group),
        outdir=lambda wc: dataset_dir(normalized_group_name(wc.group)),
        args=lambda wc: PARAMS.get("sample_pets", ""),
        cmd=CLOOPS2_CMD
    log:
        os.path.join(LOG_DIR, "normalize", "{group}.samplePETs.log")
    run:
        if not should_normalize(wildcards.group):
            raise ValueError(f"group {wildcards.group} is not configured for normalization")
        ensure_parent(output[0])
        ensure_parent(output[1])
        ensure_parent(log[0])
        target = Path(input.target).read_text().strip()
        shell(
            r'''
            mkdir -p "{params.outdir}"
            {params.cmd} samplePETs -d "{params.indir}" -o "{params.outdir}" -tot "{target}" {params.args} > "{log}" 2>&1
            touch "{output[0]}"
            '''
        )


rule qc:
    input:
        lambda wc: list(SAMPLES.values())
    output:
        f"{report_prefix('qc')}_bedpeQc.txt"
    params:
        files=",".join(SAMPLES[sample] for sample in ALL_SAMPLES),
        prefix=report_prefix("qc"),
        args=PARAMS.get("qc", ""),
        cmd=CLOOPS2_CMD
    log:
        os.path.join(LOG_DIR, "qc.log")
    shell:
        r"""
        mkdir -p "{REPORT_DIR}" "$(dirname "{log}")"
        {params.cmd} qc -f "{params.files}" -o "{params.prefix}" {params.args} > "{log}" 2>&1
        """


