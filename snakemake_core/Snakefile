rule agg_loops:
    input:
        analysis_meta_file(PRIMARY_GROUP),
        f"{report_prefix(PRIMARY_GROUP)}_loops.txt"
    output:
        touch(vis_done("agg_loops"))
    params:
        data=analysis_dataset_dir(PRIMARY_GROUP),
        loops=f"{report_prefix(PRIMARY_GROUP)}_loops.txt",
        prefix=report_prefix(PRIMARY_GROUP),
        bws=",".join([REFERENCES.get("bw_atac", ""), REFERENCES.get("bw_ctcf", "")]).strip(","),
        args=PARAMS.get("agg_loop", ""),
        cmd=CLOOPS2_CMD
    log:
        os.path.join(LOG_DIR, "vis", "agg_loops.log")
    shell:
        r"""
        mkdir -p "$(dirname "{output}")" "$(dirname "{log}")"
        {params.cmd} agg -d "{params.data}" -loops "{params.loops}" -o "{params.prefix}" {params.args} -bws "{params.bws}" > "{log}" 2>&1
        touch "{output}"
        """


rule agg_domains:
    input:
        analysis_meta_file(PRIMARY_GROUP),
        f"{report_prefix(PRIMARY_GROUP)}_domains.bed"
    output:
        touch(vis_done("agg_domains"))
    params:
        data=analysis_dataset_dir(PRIMARY_GROUP),
        domains=f"{report_prefix(PRIMARY_GROUP)}_domains.bed",
        prefix=report_prefix(PRIMARY_GROUP),
        bw=REFERENCES.get("bw_ctcf", ""),
        args=PARAMS.get("agg_domain", ""),
        cmd=CLOOPS2_CMD
    log:
        os.path.join(LOG_DIR, "vis", "agg_domains.log")
    shell:
        r"""
        mkdir -p "$(dirname "{output}")" "$(dirname "{log}")"
        {params.cmd} agg -d "{params.data}" -domains "{params.domains}" -o "{params.prefix}" {params.args} -bws "{params.bw}" > "{log}" 2>&1
        touch "{output}"
        """


