rule plot_loop:
    input:
        analysis_meta_file(PRIMARY_GROUP),
        f"{report_prefix(PRIMARY_GROUP)}_loops.txt",
        f"{report_prefix(PRIMARY_GROUP)}_peaks.bed"
    output:
        touch(vis_done("plot_loop"))
    params:
        fixy=plot_fixy(analysis_dataset_dir(PRIMARY_GROUP), "loop"),
        loops=f"{report_prefix(PRIMARY_GROUP)}_loops.txt",
        peaks=f"{report_prefix(PRIMARY_GROUP)}_peaks.bed",
        bws=",".join([REFERENCES.get("bw_atac", ""), REFERENCES.get("bw_ctcf", "")]).strip(","),
        beds=",".join([REFERENCES.get("bed_enhancer", ""), REFERENCES.get("bed_tss", ""), f"{report_prefix(PRIMARY_GROUP)}_peaks.bed"]).strip(","),
        gtf=REFERENCES.get("gtf", ""),
        prefix=f"{report_prefix(PRIMARY_GROUP)}_loop_example",
        args=f"{region_core_args('loop')} {PARAMS.get('plot_loop_extra', '')}".strip(),
        cmd=CLOOPS2_CMD
    log:
        os.path.join(LOG_DIR, "vis", "plot_loop.log")
    shell:
        r"""
        mkdir -p "$(dirname "{output}")" "$(dirname "{log}")"
        {params.cmd} plot -f "{params.fixy}" -o "{params.prefix}" {params.args} -loops "{params.loops}" -bws "{params.bws}" -beds "{params.beds}" -gtf "{params.gtf}" > "{log}" 2>&1
        touch "{output}"
        """


rule filter_pets:
    input:
        analysis_meta_file(PRIMARY_GROUP),
        f"{report_prefix(PRIMARY_GROUP)}_loops.txt"
