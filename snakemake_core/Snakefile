    params:
        data=lambda wc: analysis_dataset_dir(wc.group),
        prefix=lambda wc: report_prefix(wc.group),
        args=lambda wc: PARAMS.get("call_peaks", ""),
        cmd=CLOOPS2_CMD
    log:
        os.path.join(LOG_DIR, "calling", "{group}.callPeaks.log")
    shell:
        r"""
        mkdir -p "{REPORT_DIR}" "$(dirname "{log}")"
        {params.cmd} callPeaks -d "{params.data}" -o "{params.prefix}" {params.args} > "{log}" 2>&1
        """


