        os.path.join(DATA_DIR, f"{PRIMARY_GROUP}_filtered", "petMeta.json")
    params:
        data=analysis_dataset_dir(PRIMARY_GROUP),
        loops=f"{report_prefix(PRIMARY_GROUP)}_loops.txt",
        outdir=os.path.join(DATA_DIR, f"{PRIMARY_GROUP}_filtered"),
        args=PARAMS.get("filter_pets", ""),
        cmd=CLOOPS2_CMD
    log:
        os.path.join(LOG_DIR, "vis", "filter_pets.log")
    shell:
        r"""
        mkdir -p "$(dirname "{output[0]}")" "$(dirname "{log}")"
        {params.cmd} filterPETs -d "{params.data}" -loops "{params.loops}" -o "{params.outdir}" {params.args} > "{log}" 2>&1
        touch "{output[0]}"
        """


