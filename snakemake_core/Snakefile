rule compare_call_loops:
    wildcard_constraints:
        group=COMPARE_GROUP_PATTERN
    input:
        lambda wc: analysis_meta_file(wc.group)
    output:
        compare_loop_file("{group}")
    params:
        data=lambda wc: analysis_dataset_dir(wc.group),
        prefix=lambda wc: compare_loop_prefix(wc.group),
        args=lambda wc: PARAMS.get("compare_call_loops", ""),
        cmd=CLOOPS2_CMD
    log:
        os.path.join(LOG_DIR, "compare", "{group}.callLoops.log")
    shell:
        r"""
        mkdir -p "{REPORT_DIR}" "$(dirname "{log}")"
        {params.cmd} callLoops -d "{params.data}" -o "{params.prefix}" {params.args} > "{log}" 2>&1
        """


rule call_diff_loops:
    input:
        tmeta=analysis_meta_file(PRIMARY_GROUP),
        cmeta=analysis_meta_file(SECONDARY_GROUP),
        tloop=compare_loop_file(PRIMARY_GROUP),
        cloop=compare_loop_file(SECONDARY_GROUP)
    output:
        touch(compare_diff_done())
    params:
        td=analysis_dataset_dir(PRIMARY_GROUP),
        cd=analysis_dataset_dir(SECONDARY_GROUP),
        prefix=f"{report_prefix(PRIMARY_GROUP)}_vs_{SECONDARY_GROUP}",
        args=PARAMS.get("call_diff_loops", ""),
        cmd=CLOOPS2_CMD
    log:
        os.path.join(LOG_DIR, "compare", f"{PRIMARY_GROUP}_vs_{SECONDARY_GROUP}.callDiffLoops.log")
    shell:
        r"""
        mkdir -p "$(dirname "{output[0]}")" "$(dirname "{log}")"
        {params.cmd} callDiffLoops -tloop "{input.tloop}" -td "{params.td}" -cloop "{input.cloop}" -cd "{params.cd}" -o "{params.prefix}" {params.args} > "{log}" 2>&1
        touch "{output[0]}"
        """


rule montage_all:
    input:
        analysis_meta_file(PRIMARY_GROUP),
        analysis_meta_file(SECONDARY_GROUP)
    output:
        touch(vis_done("montage_all"))
    params:
        pfixy=os.path.join(analysis_dataset_dir(PRIMARY_GROUP), f"{CHROM_PAIR}.ixy"),
        cfixy=os.path.join(analysis_dataset_dir(SECONDARY_GROUP), f"{CHROM_PAIR}.ixy"),
        bed=REFERENCES.get("montage_bed", ""),
        pprefix=f"{report_prefix(PRIMARY_GROUP)}_montage_all",
        cprefix=f"{report_prefix(SECONDARY_GROUP)}_montage_all",
        pargs=PARAMS.get("montage_all", ""),
        cmd=CLOOPS2_CMD
    log:
        os.path.join(LOG_DIR, "compare", "montage_all.log")
    shell:
        r"""
        mkdir -p "$(dirname "{output}")" "$(dirname "{log}")"
        {params.cmd} montage -f "{params.pfixy}" -bed "{params.bed}" -o "{params.pprefix}" {params.pargs} > "{log}" 2>&1
        {params.cmd} montage -f "{params.cfixy}" -bed "{params.bed}" -o "{params.cprefix}" {params.pargs} >> "{log}" 2>&1
        touch "{output}"
        """


