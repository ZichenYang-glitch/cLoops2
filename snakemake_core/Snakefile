    input:
        SAMPLE_PRE_MARKERS + [analysis_meta_file(group) for group in ALL_GROUPS]
    output:
        touch(est_sim_done())
    params:
        dirs=",".join([dataset_dir(sample) for sample in ALL_SAMPLES] + [analysis_dataset_dir(group) for group in ALL_GROUPS]),
        prefix=report_prefix("similarity"),
        args=PARAMS.get("est_sim", ""),
        cmd=CLOOPS2_CMD
    log:
        os.path.join(LOG_DIR, "estimate", "estSim.log")
